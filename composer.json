{
    "name": "resterland/resterland",
    "type": "typo3-cms-extension",
    "description": "ResterLand extends the TYPOO3 bootstrap-package by Benjamin Kott.",
    "homepage": "https://resterland.ch/",
    "license": [
        "GPL-2.0-or-later"
    ],
    "keywords": [
        "TYPO3 CMS",
        "theme",
        "responsive"
    ],
    "require": {
        "typo3/cms-core": "^14.3"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Resterland\\Resterland\\": "Classes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "typo3/cms-*": true,
            "roave/security-advisories": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "resterland"
        }
    }
}
